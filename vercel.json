{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "py.axonsdk.dev" }],
      "destination": "/py/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "py.axonsdk.dev" }],
      "destination": "/py/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
